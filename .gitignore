# .gitignore para proyecto Python + frontend
# Ignorar entornos virtuales
.venv/
env/
.env
venv/

# Archivos de Python generados
__pycache__/
*.py[cod]
*$py.class

# Distribuciones / empaquetado
build/
dist/
*.egg-info/
pip-wheel-metadata/
.eggs/

# Archivos de test y cobertura
.coverage
.coverage.*
.cache
.pytest_cache/
nosetests.xml
coverage.xml

# Cachés y bases de datos locales
*.sqlite3
*.db
*.sqlite

# Archivos de entorno y secretos
.env
.env.*
instance/
secrets.json

# IDEs y editores
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Sistema operativo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Node
node_modules/

# Archivos Python bytecode
*.pyc
*.pyo
*.pyd

# Archivos temporales
*.tmp
*.temp
*.swp

# Archivos generados por herramientas
htmlcov/
coverage/
.python-version

# Exclude pip cache
pip-log.txt

# Añade aquí patrones adicionales según necesites
